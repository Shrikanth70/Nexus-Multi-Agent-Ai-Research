# ==============================================================================
# Nexus Research Intelligence Platform — Environment Configuration Template
# ==============================================================================
# Copy this file to `.env` and fill in your values.
# NEVER commit your real `.env` file — it is gitignored.
# This `.env.example` file IS committed as a template for contributors.
# Per SECURITY.md: All secrets must come from environment variables, never hardcoded.
# ==============================================================================


# ------------------------------------------------------------------------------
# Application Settings
# ------------------------------------------------------------------------------
NEXUS_ENV=development           # development | staging | production
NEXUS_LOG_LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR | CRITICAL
NEXUS_LOG_FORMAT=json           # json | console (use 'console' for local dev readability)
NEXUS_MAX_RETRY_COUNT=3         # Max times the Orchestrator will retry a failed agent loop
NEXUS_SESSION_TIMEOUT_SECONDS=3600


# ------------------------------------------------------------------------------
# LLM Provider Configuration
# Per ARCHITECTURE.md: Pluggable LLM design — swap providers without changing agent logic.
# Per PROJECT_VISION.md: Prioritize free/open-source. Use Ollama for local dev.
# ------------------------------------------------------------------------------

# Primary LLM Provider: openai | anthropic | ollama | gemini
LLM_PROVIDER=ollama

# OpenAI (for cloud-based execution)
OPENAI_API_KEY=sk-...your-key-here...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic (alternative cloud provider)
ANTHROPIC_API_KEY=sk-ant-...your-key-here...
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Ollama (LOCAL — free, no API key required)
# Run: `ollama pull llama3` or `ollama pull gemma3`
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_EMBEDDING_MODEL=nomic-embed-text


# ------------------------------------------------------------------------------
# Database Configuration
# Per DATABASE.md: PostgreSQL as primary datastore for production.
# Phase 1: Not required. Phase 3+: Required.
# ------------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nexus
POSTGRES_USER=nexus_user
POSTGRES_PASSWORD=your-secure-password-here
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}


# ------------------------------------------------------------------------------
# Redis Configuration
# Phase 4: Required for task queuing and caching.
# ------------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0


# ------------------------------------------------------------------------------
# Vector Store (ChromaDB — Phase 3)
# Per ARCHITECTURE.md: pgvector for production, ChromaDB for local learning.
# ------------------------------------------------------------------------------
CHROMA_PERSIST_DIRECTORY=./chroma_db
CHROMA_COLLECTION_NAME=nexus_documents


# ------------------------------------------------------------------------------
# External Tool API Keys
# Per TOOLS.md: All tool credentials must be environment-injected.
# ------------------------------------------------------------------------------

# DuckDuckGo Search — no API key needed (free, open-source)
# Tavily Search — premium quality, optional
TAVILY_API_KEY=tvly-...your-key-here...

# Serper (Google Search wrapper — optional)
SERPER_API_KEY=...your-key-here...


# ------------------------------------------------------------------------------
# Observability (Phase 4+)
# Per OBSERVABILITY.md: OpenTelemetry integration for production tracing.
# ------------------------------------------------------------------------------
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com
